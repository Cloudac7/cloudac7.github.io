---
export const prerender = true;

import MainGridLayout from "../layouts/MainGridLayout.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
---

<MainGridLayout
  title="内容受保护 · 请访问源站"
  description={i18n(I18nKey.siteDesc)}
>
  <div
    class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-96"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full flex items-center justify-center">
      <div class="text-center max-w-lg py-12">
        <div class="text-5xl mb-6 opacity-60">&#x1f512;</div>
        <h1 class="text-2xl font-bold mb-4">内容受保护</h1>
        <p class="text-lg mb-3 text-gray-600 dark:text-gray-300">
          此页面包含受保护的内容，无法在镜像站点上直接访问。
        </p>
        <p class="text-base mb-8 text-gray-500 dark:text-gray-400">
          请访问源站查看完整内容。
        </p>
        <a
          id="original-link"
          href="https://cloudac7.vercel.app/ketsu/"
          class="inline-block px-6 py-3 rounded-lg bg-sky-600 text-white font-medium hover:bg-sky-700 transition-colors"
        >
          前往源站查看 &rarr;
        </a>
      </div>
    </div>
  </div>
</MainGridLayout>

<script>
  // Construct the original Vercel URL from the current mirror path
  const link = document.getElementById("original-link");
  if (link) {
    const path = window.location.pathname;
    if (path.startsWith("/ketsu")) {
      link.href = `https://cloudac7.vercel.app${path}`;
    }
  }
</script>
