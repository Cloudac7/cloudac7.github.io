---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="404">
  <section class="flex flex-col items-center justify-center py-20">
    <h1 class="text-6xl font-bold text-[var(--color-muted)]">404</h1>
    <p class="mt-4 text-lg text-[var(--color-muted)]">页面未找到</p>
    <a href="/" class="mt-6 rounded-lg bg-primary-500 px-6 py-2 text-white transition-colors hover:bg-primary-600">
      返回首页
    </a>
  </section>
</BaseLayout>
