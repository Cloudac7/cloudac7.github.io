---
import MainGridLayout from "../layouts/MainGridLayout.astro"
---

<MainGridLayout title="404">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full flex flex-col items-center justify-center py-20">
      <h1 class="text-6xl font-bold text-black/20 dark:text-white/20">404</h1>
      <p class="mt-4 text-lg text-black/50 dark:text-white/50">页面未找到</p>
      <a href="/" class="mt-6 btn-regular rounded-xl px-6 py-2 text-sm font-medium">
        返回首页
      </a>
    </div>
  </div>
</MainGridLayout>
