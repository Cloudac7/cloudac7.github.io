---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostCard from '@/components/blog/PostCard.astro'
import Profile from '@/components/sidebar/Profile.astro'
import RecentPosts from '@/components/sidebar/RecentPosts.astro'
import CategoryNav from '@/components/sidebar/CategoryNav.astro'
import TagCloud from '@/components/sidebar/TagCloud.astro'
import { getAllPosts, getCategories, getTags } from '@/utils/posts'

const allPosts = await getAllPosts()
const categories = await getCategories()
const tags = await getTags()
---

<BaseLayout title="" description="Cloudac7 的个人博客 — オールトの雲">
  <div slot="sidebar">
    <Profile />
    <RecentPosts posts={allPosts} />
    <CategoryNav categories={categories} />
    <TagCloud tags={tags} />
  </div>

  <section>
    <h1 class="mb-6 text-2xl font-bold">最新文章</h1>
    <div class="space-y-4">
      {allPosts.map(post => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
