---
export const prerender = false;

import MainGridLayout from "@layouts/MainGridLayout.astro";
import KetsuPostCard from "@components/KetsuPostCard.astro";
import { env, isAuthenticated, createAuthCookie } from "../../utils/ketsu-auth";
import { fetchArticleList } from "../../utils/ketsu-github";

let errorMessage: string | null = null;
let articles: Awaited<ReturnType<typeof fetchArticleList>> | null = null;
let authenticated = false;

// --- POST: validate password ---
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const password = formData.get("password") as string | null;

  if (!password || !env("KETSU_PASSWORD") || password !== env("KETSU_PASSWORD")) {
    errorMessage = "密码错误。";
  } else {
    const cookieHeader = createAuthCookie();
    return new Response(null, {
      status: 302,
      headers: {
        Location: "/ketsu/",
        "Set-Cookie": cookieHeader,
      },
    });
  }
}

// --- GET: check auth ---
authenticated = isAuthenticated(Astro.request);

if (authenticated) {
  try {
    articles = await fetchArticleList();
  } catch (e) {
    if (e instanceof Error) {
      const cause = (e instanceof Error && "cause" in e) ? (e.cause instanceof Error ? e.cause.message : "") : "";
      errorMessage = `无法获取文章列表：${e.message}${cause ? " (" + cause + ")" : ""}`;
      console.error("Ketsu fetch error:", e.message);
    } else {
      errorMessage = "无法获取文章列表。请稍后再试。";
    }
  }
}
---

<MainGridLayout title="Ketsu" description="Ketsu">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  {authenticated && articles ? (
    <!-- === Authenticated: article list === -->
    <div class="flex flex-col gap-4">
      {errorMessage && (
        <div class="card-base z-10 px-6 md:px-9 py-4 relative w-full rounded-[var(--radius-large)]">
          <p class="text-red-600 dark:text-red-400 text-sm">{errorMessage}</p>
        </div>
      )}

      {articles.length === 0 && !errorMessage && (
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full rounded-[var(--radius-large)]">
          <p class="text-black/50 dark:text-white/50">暂无文章。</p>
        </div>
      )}

      {articles.map((article, i) => (
        <KetsuPostCard
          article={article}
          class="onload-animation"
          style={`animation-delay: calc(var(--content-delay) + ${i * 50}ms);`}
        />
      ))}

      <!-- logout -->
      <div class="text-center pt-2">
        <a href="/ketsu/logout/" class="text-sm text-black/40 dark:text-white/40 hover:text-[var(--primary)] transition">
          退出登录
        </a>
      </div>
    </div>
  ) : (
    <!-- === Unauthenticated: password form === -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
      <div class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
        <h2 class="text-2xl font-bold mb-6 text-black/90 dark:text-white/90">
          请输入密码
        </h2>

        {errorMessage && (
          <div class="mb-4 p-3 rounded-xl bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm">
            {errorMessage}
          </div>
        )}

        <form method="POST" action="/ketsu/" class="space-y-4 max-w-sm">
          <input
            type="password"
            name="password"
            required
            placeholder="Password"
            class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-transparent
                   text-black/80 dark:text-white/80 placeholder:text-black/30 dark:placeholder:text-white/30
                   focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent"
            autocomplete="current-password"
          />
          <button type="submit" class="btn-solid px-6 py-3 rounded-xl font-bold w-full">
            确认
          </button>
        </form>
      </div>
    </div>
  )}
</MainGridLayout>
