---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

const topics = await getCollection("topics");

// Count posts per topic
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const topicCounts = new Map<string, number>();
for (const post of allPosts) {
  if (post.data.topic) {
    topicCounts.set(post.data.topic, (topicCounts.get(post.data.topic) ?? 0) + 1);
  }
}
---

<MainGridLayout title="专栏">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h2 class="text-2xl font-bold mb-6 text-black/90 dark:text-white/90">专栏</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {topics.map(topic => (
          <a href={`/topics/${topic.slug}/`} class="btn-card rounded-2xl p-5 block">
            <h3 class="text-lg font-bold text-black/80 dark:text-white/80">{topic.data.title}</h3>
            {topic.data.description && (
              <p class="mt-1 text-sm text-black/50 dark:text-white/50">{topic.data.description}</p>
            )}
            <p class="mt-2 text-xs text-black/30 dark:text-white/30">
              {topicCounts.get(topic.slug) ?? 0} 篇文章
            </p>
          </a>
        ))}
      </div>
    </div>
  </div>
</MainGridLayout>
