---
export const prerender = true;

import { getCollection } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

export async function getStaticPaths() {
  const topics = await getCollection("topics");
  return topics.map((t) => ({
    params: { topic: t.slug },
    props: { topic: t },
  }));
}

const { topic } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const topicPosts = allPosts
  .filter((p) => p.data.topic === topic.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<MainGridLayout title={topic.data.title} description={topic.data.description}>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h2 class="text-2xl font-bold mb-2 text-black/90 dark:text-white/90">{topic.data.title}</h2>
      {topic.data.description && (
        <p class="text-sm text-black/50 dark:text-white/50 mb-4">{topic.data.description}</p>
      )}
      <p class="text-xs text-black/30 dark:text-white/30 mb-6">{topicPosts.length} 篇文章</p>

      <div class="space-y-3">
        {topicPosts.map(post => (
          <a href={`/posts/${post.slug}/`} class="btn-card rounded-xl p-4 block">
            <h3 class="font-bold text-black/80 dark:text-white/80">{post.data.title}</h3>
            {post.data.description && (
              <p class="mt-1 text-sm text-black/50 dark:text-white/50 line-clamp-2">{post.data.description}</p>
            )}
            <time class="mt-2 text-xs text-black/30 dark:text-white/30 block">
              {post.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </div>
</MainGridLayout>
