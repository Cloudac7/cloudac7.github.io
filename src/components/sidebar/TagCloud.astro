---
export interface Props {
  tags: Map<string, number>
}

const { tags } = Astro.props
const entries = Array.from(tags.entries())
---

<div class="mb-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4 shadow-sm">
  <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-[var(--color-muted)]">标签</h3>
  <div class="flex flex-wrap gap-2">
    {entries.map(([name, count]) => (
      <a
        href={`/tags/${encodeURIComponent(name)}/`}
        class="rounded-full bg-[var(--color-border)]/50 px-3 py-1 text-xs text-[var(--color-muted)] transition-colors hover:bg-primary-100 hover:text-primary-700 dark:hover:bg-primary-900/30 dark:hover:text-primary-300"
        style={`font-size: ${Math.min(0.75 + count * 0.05, 1.1)}rem`}
      >
        {name} ({count})
      </a>
    ))}
  </div>
</div>
