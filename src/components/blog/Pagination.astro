---
export interface Props {
  currentPage: number
  totalPages: number
  baseUrl: string
}

const { currentPage, totalPages, baseUrl } = Astro.props
---

{totalPages > 1 && (
  <nav class="mt-8 flex items-center justify-center gap-2">
    {currentPage > 1 && (
      <a
        href={currentPage === 2 ? baseUrl : `${baseUrl}page/${currentPage - 1}/`}
        class="rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm text-[var(--color-muted)] transition-colors hover:bg-[var(--color-border)]"
      >
        上一页
      </a>
    )}
    {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
      <a
        href={page === 1 ? baseUrl : `${baseUrl}page/${page}/`}
        class={`rounded-lg px-3 py-2 text-sm transition-colors ${
          page === currentPage
            ? 'bg-primary-500 text-white'
            : 'border border-[var(--color-border)] text-[var(--color-muted)] hover:bg-[var(--color-border)]'
        }`}
      >
        {page}
      </a>
    ))}
    {currentPage < totalPages && (
      <a
        href={`${baseUrl}page/${currentPage + 1}/`}
        class="rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm text-[var(--color-muted)] transition-colors hover:bg-[var(--color-border)]"
      >
        下一页
      </a>
    )}
  </nav>
)}
