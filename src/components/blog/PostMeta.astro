---
import Badge from '@/components/ui/Badge.astro'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  post: CollectionEntry<'posts'>
}
const { post } = Astro.props
const { data } = post
---

<div class="mb-6 flex flex-wrap items-center gap-2 text-sm text-[var(--color-muted)]">
  <time datetime={data.date.toISOString()}>
    {data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
  </time>
  {data.updated && data.updated > data.date && (
    <>
      <span>·</span>
      <span>
        更新于 {data.updated.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </span>
    </>
  )}
  <div class="flex flex-wrap gap-1.5">
    {data.categories?.map(cat => (
      <Badge href={`/categories/${encodeURIComponent(cat)}/`}>{cat}</Badge>
    ))}
  </div>
</div>

{data.tags && data.tags.length > 0 && (
  <div class="mb-6 flex flex-wrap gap-1.5">
    {data.tags.map(tag => (
      <Badge href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</Badge>
    ))}
  </div>
)}
